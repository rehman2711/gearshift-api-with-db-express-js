<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gearshift Rentals</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      font-family: Inter, sans-serif;
    }
  </style>
</head>

<body class="bg-white text-black min-h-screen flex flex-col">

  <header class="w-full bg-white">
    <div class="max-w-7xl mx-auto my-auto flex justify-between items-center px-6 py-5">

      <h1 class="text-3xl font-extrabold tracking-tight leading-none">
        GEARSHIFT
        <span class="text-yellow-500 inline-block align-bottom translate-y-[4px]">
          &#9642;
        </span>
      </h1>

      <nav class="hidden md:flex gap-8 text-base font-medium">

        <!-- 1 -->
        <a href="/api/v1/all-cars" target="_blank"
          class="text-semibold px-4 py-2 hover:bg-neutral-100 transition duration-300">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700">all-cars</span>
        </a>

        <!-- 2 -->
        <a href="/api/v1/single-car/1" target="_blank"
          class="text-semibold px-4 py-2 hover:bg-neutral-100 transition duration-300">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700">single-car</span>
        </a>

        <!-- 3 -->
        <a href="/api/v1/all-non-approved-bookings" target="_blank"
          class="text-semibold px-4 py-2 hover:bg-neutral-100 transition duration-300">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700">all-non-approved-bookings</span>
        </a>

        <!-- 4 -->
        <a href="/api/v1/all-approved-bookings" target="_blank"
          class="text-semibold px-4 py-2 hover:bg-neutral-100 transition duration-300">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700">all-approved-bookings</span>
        </a>



      </nav>

      <div class="flex gap-3">
        <a href="https://github.com/rehman2711/gearshift-backend-api-with-db-and-express-js.git" target="_blank"
          class="px-4 py-2 text-sm font-medium bg-black text-white hover:bg-black/80 transition">
          GITHUB
        </a>

        <a href="https://gearshift-api-latest.onrender.com/gearshift-api-docs/" target="_blank"
          class="px-5 py-2 text-sm font-medium bg-yellow-400 text-black hover:bg-yellow-500/90 transition">
          SWAGGER UI
        </a>
      </div>

    </div>
  </header>

  <main class="flex-1 flex items-center justify-center px-6">
    <div class="max-w-4xl mx-auto text-center">

      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight tracking-tight">
        Gearshift API .
        <br />
        <span class="bg-yellow-400 text-black px-4 py-1 inline-block mt-3">
          Made With Express Js .
        </span>
        <br />
        DB Supported .
      </h1>

      <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Access, manage, and control car rental data through structured REST APIs —
        including cars, bookings, and approval workflows .
      </p>

      <div class="mt-10 flex justify-center gap-4 flex-wrap">

