        <!-- Swagger -->
        <a href="https://gearshift-api-latest.onrender.com/gearshift-api-docs/"
          class="px-7 py-3 font-medium bg-yellow-400 text-black hover:bg-yellow-500/90 transition group flex items-center gap-2">

          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="w-7 h-7">
