  <footer class="bg-white">
    <div
      class="max-w-7xl mx-auto px-8 md:px-10 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
      <p>© <%= new Date().getFullYear() %> Gearshift Rentals</p>

      <div class="flex gap-8">
        <a href="#"
          class="px-4 py-2 hover:text-yellow-400 hover:bg-black hover:underline underline-offset-4 transition-all duration-200">
          Privacy
        </a>
        <a href="#"
          class="px-4 py-2 hover:text-yellow-400 hover:bg-black hover:underline underline-offset-4 transition-all duration-200">
          Terms
        </a>
      </div>
    </div>
  </footer>

